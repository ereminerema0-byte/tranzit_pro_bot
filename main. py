@dp.message(Command("start"))
async def cmd_start(message: types.Message, state: FSMContext):
    await state.clear()
    await message.answer(
        "Здравствуйте! Я бот ТранзитПро.\n\n"
        "Помогаю водителям находить грузы, а логистам — машины.\n\n"
        "Выберите вашу роль:",
        reply_markup=role_keyboard()
    )
    await state.set_state(UserState.waiting_role)


@dp.callback_query(F.data.startswith("role_"))
async def process_role(callback: types.CallbackQuery, state: FSMContext):
    role = callback.data.split("_")[1]
    if role == "driver":
        await callback.message.edit_text(
            "Режим водителя. Выберите действие:",
            reply_markup=driver_menu_keyboard()
        )
    else:
        await callback.message.edit_text(
            "Режим логиста. Выберите действие:",
            reply_markup=logist_menu_keyboard()
        )
    await state.update_data(role=role)
    await callback.answer()


@dp.callback_query(F.data == "cancel")
async def process_cancel(callback: types.CallbackQuery, state: FSMContext):
    data = await state.get_data()
    role = data.get("role", "driver")
    if role == "driver":
        await callback.message.edit_text(
            "Режим водителя. Выберите действие:",
            reply_markup=driver_menu_keyboard()
        )
    else:
        await callback.message.edit_text(
            "Режим логиста. Выберите действие:",
            reply_markup=logist_menu_keyboard()
        )
    await state.clear()
    await callback.answer()

@dp.callback_query(F.data == "search_cargo")
async def search_cargo_start(callback: types.CallbackQuery, state: FSMContext):
    await callback.message.edit_text(
        "Введите город отправления (или нажмите Отмена):",
        reply_markup=back_keyboard()
    )
    await state.set_state(UserState.waiting_cargo_from)
    await callback.answer()


@dp.message(UserState.waiting_cargo_from)
async def process_cargo_from(message: types.Message, state: FSMContext):
    await state.update_data(cargo_from=message.text)
    await message.answer("Введите город назначения:")
    await state.set_state(UserState.waiting_cargo_to)


@dp.message(UserState.waiting_cargo_to)
async def process_cargo_to(message: types.Message, state: FSMContext):
    data = await state.get_data()
    cargo_from = data.get("cargo_from", "")
    cargo_list = await get_cargo_list(from_city=cargo_from, to_city=message.text, exclude_user=message.from_user.id)

    if not cargo_list:
        await message.answer(
            "Грузы по такому маршруту не найдены. Попробуйте другой маршрут.",
            reply_markup=driver_menu_keyboard()
        )
        await state.clear()
        return

    text = "Найденные грузы:\n\n"
    for row in cargo_list:
        cid, f, t, w, p, ph = row
        text += f"Груз #{cid}\n{f} -> {t}\nВес: {w} т\nЦена: {p} сум\nТелефон: {ph}\n\n"

    builder = InlineKeyboardBuilder()
    builder.row(InlineKeyboardButton(text="Подписаться на маршрут", callback_data=f"sub_route:{cargo_from}:{message.text}"))
    builder.row(InlineKeyboardButton(text="В меню", callback_data="cancel"))
    await message.answer(text, reply_markup=builder.as_markup())
    await state.clear()


@dp.callback_query(F.data.startswith("sub_route:"))
async def process_sub_route(callback: types.CallbackQuery, state: FSMContext):
    parts = callback.data.split(":")
    f = parts[1]
    t = parts[2]
    await add_subscription(callback.from_user.id, f, t)
    await callback.answer("Подписка создана!", show_alert=True)
    await callback.message.answer(
        f"Вы подписаны на маршрут: {f} -> {t}\nКогда появятся новые грузы, мы вас оповестим.",
        reply_markup=driver_menu_keyboard()
    )


@dp.callback_query(F.data == "my_subscriptions")
async def my_subscriptions(callback: types.CallbackQuery):
    subs = await get_user_subscriptions(callback.from_user.id)
    if not subs:
        await callback.message.edit_text(
            "У вас нет подписок. Подписаться можно при поиске груза.",
            reply_markup=driver_menu_keyboard()
        )
        return
    text = "Ваши подписки:\n\n"
    builder = InlineKeyboardBuilder()
    for row in subs:
        sid, f, t = row
        text += f"#{sid}: {f} -> {t}\n"
        builder.row(InlineKeyboardButton(text=f"Удалить #{sid}", callback_data=f"del_sub:{sid}"))
    builder.row(InlineKeyboardButton(text="В меню", callback_data="cancel"))
    await callback.message.edit_text(text, reply_markup=builder.as_markup())
    await callback.answer()


@dp.callback_query(F.data.startswith("del_sub:"))
async def delete_sub(callback: types.CallbackQuery):
    sid = int(callback.data.split(":")[1])
    await delete_subscription(sid, callback.from_user.id)
    await callback.answer("Подписка удалена", show_alert=True)
    subs = await get_user_subscriptions(callback.from_user.id)
    if not subs:
        await callback.message.edit_text(
            "У вас нет подписок.",
            reply_markup=driver_menu_keyboard()
        )
        return
    text = "Ваши подписки:\n\n"
    builder = InlineKeyboardBuilder()
    for row in subs:
        sid, f, t = row
        text += f"#{sid}: {f} -> {t}\n"
        builder.row(InlineKeyboardButton(text=f"Удалить #{sid}", callback_data=f"del_sub:{sid}"))
    builder.row(InlineKeyboardButton(text="В меню", callback_data="cancel"))
    await callback.message.edit_text(text, reply_markup=builder.as_markup())


