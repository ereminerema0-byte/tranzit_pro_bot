def role_keyboard():
    builder = InlineKeyboardBuilder()
    builder.row(
        InlineKeyboardButton(text="Водитель", callback_data="role_driver"),
        InlineKeyboardButton(text="Логист", callback_data="role_logist")
    )
    return builder.as_markup()


def driver_menu_keyboard():
    builder = InlineKeyboardBuilder()
    builder.row(InlineKeyboardButton(text="Поиск груза", callback_data="search_cargo"))
    builder.row(InlineKeyboardButton(text="Мои подписки", callback_data="my_subscriptions"))
    builder.row(InlineKeyboardButton(text="Разместить машину", callback_data="add_truck"))
    builder.row(InlineKeyboardButton(text="Мои объявления", callback_data="my_trucks"))
    return builder.as_markup()


def logist_menu_keyboard():
    builder = InlineKeyboardBuilder()
