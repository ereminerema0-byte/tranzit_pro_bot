    waiting_truck_price = State()
    waiting_truck_phone = State()
    waiting_subscription_route = State()
    waiting_role = State()


async def init_db():
    async with aiosqlite.connect(DB_PATH) as db:
        await db.execute('''
            CREATE TABLE IF NOT EXISTS cargo (
                id INTEGER PRIMARY KEY AUTOINCREMENT,
                user_id INTEGER,
                from_city TEXT,
                to_city TEXT,
                weight TEXT,
                price TEXT,
                phone TEXT,
                created_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP
            )
        ''')
        await db.execute('''
            CREATE TABLE IF NOT EXISTS trucks (
                id INTEGER PRIMARY KEY AUTOINCREMENT,
                user_id INTEGER,
                from_city TEXT,
                to_city TEXT,
                capacity TEXT,
                price TEXT,
                phone TEXT,
                created_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP
            )
        ''')
        await db.execute('''
            CREATE TABLE IF NOT EXISTS subscriptions (
                id INTEGER PRIMARY KEY AUTOINCREMENT,
                user_id INTEGER,
                from_city TEXT,
                to_city TEXT,
                created_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP
            )
        ''')
        await db.execute('''
            CREATE TABLE IF NOT EXISTS users (
                user_id INTEGER PRIMARY KEY,
                role TEXT,
                phone TEXT
            )
        ''')
        await db.commit()


async def add_cargo(user_id, from_city, to_city, weight, price, phone):
    async with aiosqlite.connect(DB_PATH) as db:
        await db.execute(
            "INSERT INTO cargo (user_id, from_city, to_city, weight, price, phone) VALUES (?, ?, ?, ?, ?, ?)",
            (user_id, from_city, to_city, weight, price, phone)
        )
        await db.commit()


async def add_truck(user_id, from_city, to_city, capacity, price, phone):
    async with aiosqlite.connect(DB_PATH) as db:
        await db.execute(
            "INSERT INTO trucks (user_id, from_city, to_city, capacity, price, phone) VALUES (?, ?, ?, ?, ?, ?)",
            (user_id, from_city, to_city, capacity, price, phone)
        )
        await db.commit()


async def get_cargo_list(from_city=None, to_city=None, exclude_user=None):
    async with aiosqlite.connect(DB_PATH) as db:
        query = "SELECT id, from_city, to_city, weight, price, phone FROM cargo WHERE 1=1"
        params = []
        if from_city:
            query += " AND LOWER(from_city) LIKE LOWER(?)"
            params.append(f"%{from_city}%")
        if to_city:
            query += " AND LOWER(to_city) LIKE LOWER(?)"
            params.append(f"%{to_city}%")
        if exclude_user:
            query += " AND user_id != ?"
            params.append(exclude_user)
        query += " ORDER BY created_at DESC LIMIT 20"
        async with db.execute(query, params) as cursor:
            return await cursor.fetchall()


