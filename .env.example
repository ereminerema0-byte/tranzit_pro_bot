BOT_TOKEN=your_bot_token_here

# user (default) — контакт того, кто разместил объявление
# hub — всегда контакт биржи (CONTACT_USERNAME)
# hybrid — контакт автора + контакт биржи
CONTACT_MODE=user
# Опционально: контакт биржи (только для hub/hybrid). НЕ подставляется вместо автора.
CONTACT_USERNAME=

ADMIN_ID=your_telegram_id
CHANNEL_ID=-100xxxxxxxxxx
DATABASE_PATH=bot.db
